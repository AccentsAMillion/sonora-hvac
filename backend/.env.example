# ─────────────────────────────────────────────────────────────────────────────
# Sonora HVAC Backend — Environment Variables
# Copy this file to .env and fill in your values.
# The app runs with just OPENAI_API_KEY; all other integrations degrade gracefully.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Optional: Twilio SMS ──────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15551234567

# ── Optional: GoHighLevel CRM Integration ────────────────────────────────────
GHL_API_KEY=your_ghl_api_key
GHL_LOCATION_ID=your_ghl_location_id
GHL_WEBHOOK_SECRET=your_ghl_webhook_secret

# ── App Configuration ─────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=false
DATABASE_PATH=sonora_hvac.db
SECRET_KEY=change-me-to-a-random-secret-key-in-production

# ── Audio / TTS ───────────────────────────────────────────────────────────────
TTS_VOICE=nova
TTS_MODEL=tts-1
WHISPER_MODEL=whisper-1

# ── Follow-Up Engine ─────────────────────────────────────────────────────────
MISSED_CALL_DELAY_SECONDS=120
FOLLOWUP_ENGINE_INTERVAL_SECONDS=60

# ─────────────────────────────────────────────────────────────────────────────
# Sonora HVAC — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Business Config ───────────────────────────────────────────────────────────
BUSINESS_NAME=Desert Air HVAC
SERVICE_AREA=Phoenix, AZ
BOOKING_HOURS=7am-7pm Monday-Saturday

# ── Database ──────────────────────────────────────────────────────────────────
# On Railway: set to /app/data/sonora_hvac.db and mount a volume at /app/data
# Locally: leave as default
DATABASE_PATH=sonora_hvac.db

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your Netlify URL in production (e.g. https://sonora-hvac.netlify.app)
# Leave as * for local development
ALLOWED_ORIGINS=*

# ── Optional: Twilio SMS ──────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Optional: GoHighLevel CRM ─────────────────────────────────────────────────
GHL_API_KEY=
GHL_LOCATION_ID=

# ── Optional: ElevenLabs (voice clone replacement for OpenAI nova) ────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=production
DEBUG=false
SECRET_KEY=change-this-to-a-random-secret-key
